{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ES2015",
    "lib": ["DOM", "ES2015"],
    "outDir": "./source/scripts",
    "rootDir": "./source/scripts",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "source/scripts/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
